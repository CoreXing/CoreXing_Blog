---
import NavBar from "@/components/navbar/NavBar.svelte";
import Brand from "@/components/Brand.astro";
import HeaderCover from "@/components/HeaderCover.astro";
import Waves from "@/components/Waves.astro";
import { getCollection } from "astro:content";
import type {
  TocItem,
  RelatedPost,
  QuickNavigation,
} from "@/components/sidebar/SidebarTypes";
import "@/styles/view-transition.css";
import "@vtbag/element-crossing?url";

import themeConfig from "@/theme.config.ts";

import "@/styles/palette.css";
import "@/styles/style.css";
import "@/styles/header-cover.css";
import "@/styles/mdx-components.css";

import Loading from "@/components/Loading.astro";
import { covers, resolveFixedCover } from "@/components/Images.astro";
import FloatingToolbar from "@/components/FloatingToolbar.svelte";
import TwoColumnLayout from "@/layouts/TwoColumnLayout.astro";
import ThreeColumnLayout from "@/layouts/ThreeColumnLayout.astro";
import { generateTagCloud } from "@/toolkit/posts/generateTagCloud";

const baseUrl: string = ((import.meta as any).env?.BASE_URL as string) || "/";
const baseNoTrailingSlash =
  baseUrl.length > 1 && baseUrl[baseUrl.length - 1] === "/"
    ? baseUrl.slice(0, -1)
    : baseUrl;
const withBase = (path: string): string => {
  if (!path) return path;
  if (/^[a-zA-Z][a-zA-Z\d+\-.]*:/.test(path)) return path;
  if (path[0] === "#") return path;
  if (path === baseNoTrailingSlash || path.indexOf(`${baseNoTrailingSlash}/`) === 0)
    return path;
  if (path[0] === "/") return `${baseNoTrailingSlash}${path}`;
  return `${baseUrl}${path}`;
};

// Accept sidebar props from child pages
interface PostMeta {
  date: Date;
  wordCount: number;
  readTime: number;
}

interface Props {
  toc?: TocItem[];
  relatedPosts?: RelatedPost[];
  currentSlug?: string;
  navigation?: QuickNavigation;
  pageTitle?: string;
  postMeta?: PostMeta;
  indexPage?: boolean;
}

const {
  toc = [],
  relatedPosts = [],
  currentSlug = "",
  navigation = {},
  pageTitle = "",
  postMeta,
  indexPage = false,
} = Astro.props;

const navLinks = themeConfig.nav;
const siteName = themeConfig.siteName;
const sidebarConfig = themeConfig.sidebar || {};
const brandConfig = themeConfig.brand || {};
const coverConfig = themeConfig.cover || {};
const footerConfig = themeConfig.footer || {};
const widgetsConfig = themeConfig.widgets || {};
const commentsConfig = themeConfig.comments || {};
const walineConfig = commentsConfig.waline || {};
const tagCloudConfig = themeConfig.tagCloud || {};
const visibilityTitleConfig = themeConfig.visibilityTitle || {};
const layoutConfig = themeConfig.layout || {};
const rightSidebarConfig = layoutConfig.rightSidebar || {};
const layoutMode = layoutConfig.mode || "two-column";
const enableThirdColumn = layoutMode === "three-column";
const shouldComputeRightSidebarRandomPosts =
  enableThirdColumn && rightSidebarConfig.randomPosts === true;
const shouldComputeRightSidebarRecentMoments =
  enableThirdColumn && rightSidebarConfig.recentMoments === true;
const shouldComputeRightSidebarTagCloud =
  enableThirdColumn && rightSidebarConfig.tagCloud === true;
const ActiveLayout = enableThirdColumn ? ThreeColumnLayout : TwoColumnLayout;

// fixedCover：通过 Images.astro 统一解析（静态导入走 <Image />，字符串走 <img> 兜底）
const fixedCover = coverConfig.fixedCover?.enable
  ? resolveFixedCover(coverConfig.fixedCover.url)
  : undefined;

// Get all posts for widgets
const allPosts = await getCollection("posts");
const posts = allPosts.filter((post) => !post.data.draft);
const moments = shouldComputeRightSidebarRecentMoments
  ? (await getCollection("moments")).sort(
      (a, b) =>
        new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
    )
  : [];
const rightSidebarPosts = shouldComputeRightSidebarRandomPosts
  ? posts.filter((post) => !post.data.encrypted && !post.data.link)
  : [];
const rightSidebarTagCloud = shouldComputeRightSidebarTagCloud
  ? (() => {
      const rightSidebarTagCounts = posts.reduce((acc, post) => {
        post.data.tags?.forEach((tag) => {
          acc.set(tag, (acc.get(tag) || 0) + 1);
        });

        return acc;
      }, new Map<string, number>());

      return generateTagCloud(
        Array.from(rightSidebarTagCounts.entries()).map(([name, count]) => ({
          name,
          count,
        })),
        {
          minFontSize: 12,
          maxFontSize: 20,
          startColor: tagCloudConfig.startColor,
          endColor: tagCloudConfig.endColor,
          limit: 16,
        },
      ).map((tag) => ({
        ...tag,
        href: `/tags/${encodeURIComponent(tag.name.toLowerCase().replace(/\s+/g, "-"))}/`,
      }));
    })()
  : [];

const siteState = {
  categories: allPosts.reduce((acc, post) => {
    post.data.categories?.forEach((category) => acc.add(category));
    return acc;
  }, new Set()).size,
  posts: posts.length,
  tags: allPosts.reduce((acc, post) => {
    post.data.tags?.forEach((tag) => acc.add(tag));
    return acc;
  }, new Set()).size,
};

// Import CodeBlock to define custom element
import CodeBlock from "@/components/CodeBlock.svelte";
import SearchPage from "@/components/search/SearchPage.svelte";
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <meta name="generator" content={Astro.generator} />

    <slot name="head" />

    <meta http-equiv="X-Content-Type-Options" content="nosniff" />

    <title>{pageTitle}</title>
  </head>
  <body
    data-visibility-title-config={JSON.stringify(visibilityTitleConfig)}
    data-base-url={(import.meta as any).env?.BASE_URL}
  >
    <NavBar
      client:load
      name={siteName}
      navLinks={navLinks}
      clickToggleCallback={() => void 0}
    />
    <SearchPage client:idle selector="#search" />
    <Loading />
    <div id="container">
      <HeaderCover
        enable={coverConfig.enable}
        preload={coverConfig.preload}
        fixedCover={fixedCover}
        gradient={coverConfig.gradient}
        covers={covers}
        title={brandConfig.title}
      />
      <Brand
        title={brandConfig.title}
        subtitle={brandConfig.subtitle}
        logo={brandConfig.logo}
        pageTitle={indexPage ? "" : pageTitle}
        postMeta={postMeta}
      />
      <Waves />
      <main>
        <ActiveLayout
          posts={posts}
          widgetsConfig={widgetsConfig}
          commentsEnabled={Boolean(themeConfig.comments?.enable)}
          walineServerURL={walineConfig.serverURL || ""}
          footerConfig={footerConfig}
          siteName={siteName}
          author={sidebarConfig.author}
          sidebarConfig={sidebarConfig}
          rightSidebarConfig={rightSidebarConfig}
          rightSidebarPosts={rightSidebarPosts}
          rightSidebarMoments={moments}
          rightSidebarTagCloud={rightSidebarTagCloud}
          navLinks={navLinks}
          toc={toc}
          relatedPosts={relatedPosts}
          currentSlug={currentSlug}
          navigation={navigation}
          siteState={siteState}
        >
          <slot />
        </ActiveLayout>
      </main>
    </div>
    <script>
      import "@/toolkit/initMdxComponents";
    </script>
    <script>
      import { css } from "@/assets/fonts/LXGWWenKai-Regular.ttf?subsets";

      document.addEventListener("pagereveal", () => {
        document.body.style.fontFamily = css.family as string;
      });
      document.addEventListener("DOMContentLoaded", () => {
        document.body.style.fontFamily = css.family as string;
      });
    </script>
    <script>
      type VisibilityTitleScriptConfig = {
        enable: boolean;
        leaveTitle: string;
        returnTitle: string;
        restoreDelay: number;
      };

      const parseVisibilityTitleConfig = () => {
        const raw = document.body.dataset.visibilityTitleConfig;
        if (!raw) {
          return {} as Partial<VisibilityTitleScriptConfig>;
        }

        try {
          const parsed = JSON.parse(raw) as unknown;
          if (typeof parsed === "object" && parsed !== null) {
            return parsed as Partial<VisibilityTitleScriptConfig>;
          }
        } catch {
          // ignore malformed JSON and fallback to defaults
        }

        return {} as Partial<VisibilityTitleScriptConfig>;
      };

      const visibilityTitleConfigData = parseVisibilityTitleConfig();
      const config = {
        enable: visibilityTitleConfigData.enable ?? true,
        leaveTitle:
          visibilityTitleConfigData.leaveTitle ?? "(╥﹏╥) 不要走嘛...",
        returnTitle:
          visibilityTitleConfigData.returnTitle ?? "(๑•̀ㅂ•́)و✧ 欢迎回来！",
        restoreDelay: visibilityTitleConfigData.restoreDelay ?? 3000,
      };

      if (config.enable) {
        let originalTitle = document.title;
        let restoreTimer: number | undefined;

        const clearRestoreTimer = () => {
          if (restoreTimer !== undefined) {
            window.clearTimeout(restoreTimer);
            restoreTimer = undefined;
          }
        };

        const onVisibilityChange = () => {
          clearRestoreTimer();

          if (document.hidden) {
            originalTitle = document.title;
            document.title = config.leaveTitle;
            const delay =
              Number.isFinite(config.restoreDelay) && config.restoreDelay >= 0
                ? config.restoreDelay
                : 3000;

            restoreTimer = window.setTimeout(() => {
              document.title = originalTitle;
            }, delay);
            return;
          }

          document.title = config.returnTitle;
          const delay =
            Number.isFinite(config.restoreDelay) && config.restoreDelay >= 0
              ? config.restoreDelay
              : 3000;

          restoreTimer = window.setTimeout(() => {
            document.title = originalTitle;
          }, delay);
        };

        document.addEventListener("visibilitychange", onVisibilityChange);
      }
    </script>
    <script is:inline>
      (() => {
        const baseUrl = document.body?.dataset?.baseUrl || "/";
        if (!baseUrl || baseUrl === "/") return;

        const baseWithTrailing = baseUrl.endsWith("/") ? baseUrl : `${baseUrl}/`;
        const baseNoTrailing = baseWithTrailing.replace(/\/$/, "");

        const isSpecialScheme = (href) =>
          /^[a-zA-Z][a-zA-Z\d+\-.]*:/.test(href);

        const fixAnchor = (a) => {
          const raw = a.getAttribute("href");
          if (!raw) return;
          if (raw.startsWith("#")) return;
          if (raw.startsWith("//")) return;
          if (isSpecialScheme(raw)) return;
          if (!raw.startsWith("/")) return;
          if (raw.startsWith(baseWithTrailing) || raw === baseNoTrailing) return;

          a.setAttribute("href", `${baseNoTrailing}${raw}`);
        };

        const fixAnchorsIn = (root) => {
          if (!root) return;
          if (root instanceof HTMLAnchorElement) {
            fixAnchor(root);
            return;
          }
          const anchors = root.querySelectorAll
            ? root.querySelectorAll('a[href^="/"]')
            : [];
          anchors.forEach(fixAnchor);
        };

        const fixAll = () => fixAnchorsIn(document);

        // Initial + Astro client-side navigations
        document.addEventListener("DOMContentLoaded", fixAll, { once: true });
        document.addEventListener("astro:page-load", fixAll);

        // Catch dynamically injected links (e.g. plugins/widgets)
        const observer = new MutationObserver((mutations) => {
          for (const m of mutations) {
            m.addedNodes?.forEach((n) => {
              if (n && n.nodeType === 1) fixAnchorsIn(n);
            });
          }
        });
        observer.observe(document.documentElement, { subtree: true, childList: true });

        // Safety net: intercept clicks on still-unfixed root-absolute links
        document.addEventListener(
          "click",
          (e) => {
            const evt = e;
            if (evt.defaultPrevented) return;
            if (evt.button !== 0) return;
            if (evt.metaKey || evt.ctrlKey || evt.shiftKey || evt.altKey) return;

            const target = evt.target;
            const a = target?.closest?.("a");
            if (!a) return;
            if (a.target && a.target !== "_self") return;

            const raw = a.getAttribute("href");
            if (!raw || !raw.startsWith("/")) return;
            if (raw.startsWith(baseWithTrailing)) return;

            evt.preventDefault();
            window.location.assign(`${baseNoTrailing}${raw}`);
          },
          true,
        );
      })();
    </script>
    <div class="hidden">
      <CodeBlock client:idle />
    </div>
    <FloatingToolbar client:idle nyxPlayer={themeConfig.nyxPlayer} />
  </body>
</html>

<style>
  body {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
  }
</style>
